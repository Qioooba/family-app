# 环境变量配置文件
# 复制此文件为 .env 并填写真实值

# 后端基础配置
APP_BASE_URL=http://localhost:8443
APP_PUBLIC_ORIGIN=http://localhost:8443
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# MySQL
MYSQL_URL=jdbc:mysql://localhost:3306/family_app?useUnicode=true&characterEncoding=utf-8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
MYSQL_USERNAME=root
MYSQL_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 鉴权
SA_TOKEN_JWT_SECRET=change-me-in-production

# 文件上传
FILE_UPLOAD_PATH=./uploads
FILE_UPLOAD_BASE_URL=${APP_BASE_URL}

# 微信小程序
WEIXIN_APPID=
WEIXIN_APPSECRET=

# 腾讯地图
TENCENT_MAP_KEY=

# SSL
SSL_KEY_STORE=classpath:qioba.cn.p12
SSL_KEY_STORE_PASSWORD=

# 企业微信
WECHAT_WORK_CORPID=
WECHAT_WORK_AGENTID=
WECHAT_WORK_SECRET=
